# .env.example — Reference only.
# Production uses Docker secrets (secrets/*.txt), never .env.
# ------------------------------
# Database (used by backend + dashboard)
# ------------------------------
# DB_HOST=db
# DB_PORT=3306
# DB_USER=resort_app
# DB_NAME=resort_db

# ------------------------------
# Backend
# ------------------------------
# ADMIN_SECRET_TOKEN=replace_with_64_char_hex_random_secret
# DISABLE_DOCS=true
# ALLOWED_ORIGINS=https://rosyohospitality.com.np,https://www.rosyohospitality.com.np
# LOG_LEVEL=INFO

# ------------------------------
# Dashboard
# ------------------------------
# DASHBOARD_PASSWORD=replace_with_strong_admin_password
# LOG_LEVEL=INFO
